# filename: .gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
env/
ENV/
env.bak/
venv.bak/

# IDE settings
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Test coverage
.coverage
htmlcov/
.tox/

# Logs and databases
*.log
*.sqlite
*.db

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# Temporary files
*.tmp
*.temp
